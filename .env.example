# OCR provider strategy.
# auto: try local OCR engines first, then Baidu OCR if keys are configured.
# baidu: force Baidu OCR for image uploads.
OCR_PROVIDER=auto

# Optional Baidu OCR provider.
# Copy this file to .env and fill your own keys.
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_LANGUAGE_TYPE=CHN_ENG
BAIDU_OCR_DETECT_DIRECTION=true
BAIDU_OCR_ENDPOINT=https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic
